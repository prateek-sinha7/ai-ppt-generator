# ─────────────────────────────────────────────────────────────────────────────
# AI Presentation Intelligence Platform — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Application ──────────────────────────────────────────────────────────────
APP_ENV=development
# Strong random secret — generate with: openssl rand -hex 32
SECRET_KEY=change-me-to-a-strong-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# ── Database (PostgreSQL) ─────────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=presentations
# Used by the backend service directly
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/presentations

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ── MinIO (S3-compatible object storage) ──────────────────────────────────────
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=presentations
MINIO_USE_SSL=false

# ── LLM Provider Configuration ────────────────────────────────────────────────
# Primary provider: claude | openai | groq | local
LLM_PRIMARY_PROVIDER=claude
# Ordered comma-separated fallback list (leave empty for no fallback)
LLM_FALLBACK_PROVIDERS=groq,openai

# Provider API keys — only the keys for configured providers are required
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GROQ_API_KEY=
# For local LLM (e.g. Ollama): http://localhost:11434/v1
LOCAL_LLM_ENDPOINT=

# ── LangSmith Observability ───────────────────────────────────────────────────
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=ai-presentation-platform
# Set to true to enable LangChain tracing
LANGCHAIN_TRACING_V2=false

# ── Cost Control ──────────────────────────────────────────────────────────────
MAX_LLM_CALLS_PER_REQUEST=4
COST_CEILING_USD=1.0
TENANT_DAILY_COST_THRESHOLD_USD=10.0
# Optional webhook URL for cost alerts (leave empty to disable)
COST_ALERT_WEBHOOK_URL=
